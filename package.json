{
  "name": "@bollgade/eslint-config",
  "version": "1.0.0",
  "description": "One-stop ESLint flat config for TypeScript, Node, NestJS, React, and Next.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "eslint flat config",
    "flat config",
    "typescript",
    "prettier",
    "import",
    "unused-imports",
    "node",
    "nestjs",
    "react",
    "next",
    "nextjs",
    "bollgade"
  ],
  "author": "Bollgade <bollgade@gmail.com>",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --minify",
    "prepublishOnly": "npm run build",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --max-warnings=0",
    "lint:ts:fix": "npm run lint:ts -- --fix",
    "type-check": "tsc --project ./tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bollgade/eslint-config.git"
  },
  "bugs": "https://github.com/bollgade/eslint-config/issues",
  "homepage": "https://github.com/bollgade/eslint-config#readme",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.18.0",
    "@stylistic/eslint-plugin": "^5.2.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.0.0",
    "local-pkg": "^0.5.1",
    "typescript-eslint": "^8.40.0"
  },
  "optionalDependencies": {
    "@next/eslint-plugin-next": "^15.0.0",
    "eslint-plugin-i18next": "^6.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-component-name": "^2.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "jiti": "2.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
